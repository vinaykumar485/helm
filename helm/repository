Most commaon Helm epository command

# Add repository
helm repo add bitnami https://charts.bitnami.com/bitnami

# List repositories
helm repo list

# Update repository index
helm repo update

# Search charts
helm search repo <chartname>

# Search all versions
helm search repo <chart name> --versions

# Show chart metadata
helm show chart<chat name>  

# Show default values
helm show values <chat name>

# Install chart
helm install <release name> <chart name>

# List installed releases
helm list

# Check status
helm status <release name>

# Remove release
helm uninstall <release name>


